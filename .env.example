# Render Server Environment Configuration
# Copy this as .env in Render environment variables

# YOLO Model Paths (already local in repo)
TACTILE_MODEL=best.pt
OBSTACLE_MODEL=yolov8n.pt

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=0

# Cache Configuration (auto-set by yolo_config.py, but can override)
# YOLO_CACHE=/tmp/yolo_cache
# YOLO_CONFIG_DIR=/tmp/yolo_cache/config

# Port for Flask
PORT=5000
